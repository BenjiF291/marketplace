rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to users and items collections
    match /users/{userId} {
      allow read, write: if true;
    }

    match /items/{itemId} {
      allow read, write: if true;
    }

    // Allow access to test collection for debugging
    match /test/{testId} {
      allow read, write: if true;
    }
  }
}